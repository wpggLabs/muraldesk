{
  "name": "muraldesk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5000",
    "dev:web": "vite --host 0.0.0.0 --port 5000",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "dev:desktop": "concurrently -k -n vite,electron -c \"cyan,magenta\" \"npm run dev:renderer\" \"wait-on http-get://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "build:desktop": "npm run build:web && electron-builder --win",
    "build:desktop:dir": "npm run build:web && electron-builder --win --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.6",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.muraldesk.app",
    "productName": "MuralDesk",
    "copyright": "Copyright © 2026 MuralDesk",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "MuralDesk-Setup-${version}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MuralDesk"
    }
  }
}
